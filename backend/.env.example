# ============================================
# EduNex AI Tutor — Environment Variables
# ============================================
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️ SECURITY WARNINGS:
#   1. NEVER commit the .env file to version control.
#   2. NEVER hardcode real API keys or passwords in source code.
#   3. If any credential has been exposed (e.g. pushed to GitHub),
#      rotate it IMMEDIATELY:
#        - Groq API Key:  https://console.groq.com/keys
#        - Redis Password: Your cloud provider dashboard
#   4. Use a secrets manager (e.g. AWS Secrets Manager, GCP Secret
#      Manager, or Doppler) for production deployments.
# ============================================

# ── Groq AI (REQUIRED) ────────────────────────────────
# Get your key at: https://console.groq.com/keys
# ⚠️ Replace with your actual key. Do NOT share this key.
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama3-8b-8192

# ── MongoDB ───────────────────────────────────────────
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=edunex_ai

# ── Redis (Cloud) ────────────────────────────────────
# Format: redis://username:password@host:port
# TLS:    rediss://username:password@host:port
#
# Examples:
#   Upstash:    rediss://default:your_password@your-endpoint.upstash.io:6379
#   Redis Labs: redis://default:your_password@redis-12345.c1.us-east.cloud.redislabs.com:12345
#   Local:      redis://localhost:6379/0
#
# ⚠️ Replace with your actual Cloud Redis URL. Do NOT share credentials.
REDIS_URL=redis://localhost:6379/0

# Force SSL even if URL uses redis:// scheme (set to true for cloud providers)
REDIS_SSL=false

# Connection tuning (seconds)
REDIS_CONNECT_TIMEOUT=5.0
REDIS_SOCKET_TIMEOUT=5.0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=50

# ── App ───────────────────────────────────────────────
APP_NAME=EduNex AI Tutor
APP_VERSION=1.0.0
# Set to "false" or "production" for production deployments
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Memory ────────────────────────────────────────────
# TTL for short-term chat memory in Redis (seconds)
CHAT_MEMORY_TTL=3600
# Maximum number of messages kept in short-term memory per session
MAX_MEMORY_MESSAGES=20
